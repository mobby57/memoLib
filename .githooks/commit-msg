#!/bin/sh

MSG_FILE="$1"
PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .{3,}$'

if ! grep -Eq "$PATTERN" "$MSG_FILE"; then
  echo "Message de commit invalide."
  echo "Format attendu: type(scope): description"
  echo "Exemple: feat(auth): add refresh token rotation"
  exit 1
fi

exit 0
