#!/bin/sh

STAGED_FILES=$(git diff --cached --name-only)
FORMATTED_FILES=$(printf '%s
' "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx|json|md|css|scss|yml|yaml)$' || true)
POWERSHELL_FILES=$(printf '%s
' "$STAGED_FILES" | grep -E '\.ps1$' || true)
SHELL_FILES=$(printf '%s
' "$STAGED_FILES" | grep -E '\.sh$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

if ! git diff --cached --check; then
  echo "Commit bloque: corrige les erreurs signalees par git diff --cached --check."
  exit 1
fi

if printf '%s
' "$STAGED_FILES" | grep -Eq '\.tsbuildinfo$'; then
  echo "Commit bloque: les fichiers .tsbuildinfo ne doivent pas etre versionnes."
  exit 1
fi

if printf '%s
' "$STAGED_FILES" | grep -Eq '^package.json$'; then
  if ! node -e "JSON.parse(require('fs').readFileSync('package.json','utf8'));"; then
    echo "Commit bloque: package.json est invalide."
    exit 1
  fi
fi

if [ -n "$POWERSHELL_FILES" ] && command -v powershell >/dev/null 2>&1; then
  while IFS= read -r file; do
    if ! powershell -NoProfile -Command "\$errors = \$null; [System.Management.Automation.Language.Parser]::ParseFile('$file', [ref]\$null, [ref]\$errors) | Out-Null; if (\$errors.Count -gt 0) { exit 1 }"; then
      echo "Commit bloque: erreur de syntaxe PowerShell dans $file."
      exit 1
    fi
  done <<EOF
$POWERSHELL_FILES
EOF
fi

if [ -n "$SHELL_FILES" ]; then
  while IFS= read -r file; do
    if ! sh -n "$file"; then
      echo "Commit bloque: erreur de syntaxe shell dans $file."
      exit 1
    fi
  done <<EOF
$SHELL_FILES
EOF
fi

if [ -n "$FORMATTED_FILES" ] && command -v npx >/dev/null 2>&1; then
  if ! printf '%s
' "$FORMATTED_FILES" | xargs npx prettier --check --ignore-unknown >/dev/null 2>&1; then
    echo "Commit bloque: Prettier signale des fichiers mal formates parmi les fichiers indexes."
    exit 1
  fi
fi

exit 0
