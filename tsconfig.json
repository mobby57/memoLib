{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "incremental": true,
    "strict": false,
    "noImplicitAny": false,
    "tsBuildInfoFile": ".tsbuildinfo",
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "5.0",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@front/*": ["./src/frontend/*"],
      "@/components/*": ["./src/components/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/types/*": ["./src/types/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/services/*": ["./src/services/*"],
      "@/app/*": ["./src/app/*"],
      "@/pages/*": ["./src/pages/*"]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/frontend/**/*.ts",
    "src/frontend/**/*.tsx",
    "sentry.client.config.ts",
    "sentry.server.config.ts",
    "sentry.edge.config.ts",
    "instrumentation.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "node_modules_backup",
    ".next",
    "out",
    "dist",
    "code-connect",
    "__tests__/**",
    "src/frontend/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "scripts/**",
    "prisma/**",
    "__mocks__/**",
    "coverage/**",
    "src/frontend/app/demo/**",
    "src/lib/ai/**",
    "src/lib/email/**",
    "src/lib/cache/redis.ts",
    "src/lib/dev/advanced-logger.ts",
    "src/lib/billing/stripe-client.ts",
    "src/lib/cron/legal-proof-purge.ts",
    "src/examples/**",
    "src/figma.config.ts",
    "src/frontend/app/api/**",
    "src/frontend/app/[locale]/dashboard-secure/**",
    "**/*.backup.ts",
    "**/*.migrated.ts",
    "lib/ai/**",
    "lib/dev/**",
    "lib/email/**",
    "lib/github/**",
    "lib/legifrance/**",
    "lib/multichannel/**",
    "lib/security/**",
    "lib/workflows/**",
    "lib/workspace-reasoning-service.ts",
    "lib/sentry-release-health.ts",
    "lib/services/collaboration.service.ts",
    "lib/services/deadline-monitor.service.ts",
    "lib/services/filter-rule.service.ts",
    "lib/services/information-unit.service.ts",
    "lib/services/learningService.ts",
    "lib/services/smart-inbox.service.ts",
    "lib/services/encryption.ts",
    "lib/billing/stripe-client.ts"
  ]
}
