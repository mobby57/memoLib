# =============================================================================
# MemoLib - Variables d'environnement Docker
# =============================================================================
# Copier ce fichier: cp .env.docker.example .env.docker
# Puis editer avec vos valeurs reelles
# =============================================================================

# --- JWT (OBLIGATOIRE - generer avec: openssl rand -base64 64) ---
JWT_SECRET_KEY=CHANGEZ_MOI_AVEC_UNE_CLE_DE_64_CARACTERES_MINIMUM_SECURISEE

# --- PostgreSQL ---
POSTGRES_USER=memolib
POSTGRES_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_POSTGRES

# --- Redis ---
REDIS_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_REDIS

# --- Email Monitor (Gmail IMAP) ---
EMAIL_MONITOR_ENABLED=false
EMAIL_USERNAME=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application-gmail

# --- Vault ---
VAULT_MASTER_KEY=

# --- Domaine (pour CORS et Nginx) ---
DOMAIN=memolib.local

# --- Seq (logs) ---
SEQ_API_KEY=

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_GRAFANA

# --- pgAdmin ---
PGADMIN_EMAIL=admin@memolib.local
PGADMIN_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_PGADMIN
