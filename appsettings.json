{
    "Vault":  {
                  "MasterKey":  ""
              },
    "ConnectionMonitor":  {
                              "IntervalMinutes":  5
                          },
    "Kestrel":  {
                    "Endpoints":  {
                                      "Http":  {
                                                   "Url":  "http://0.0.0.0:5078"
                                               }
                                  }
                },
    "AllowedHosts":  "*",
    "EmailMonitor":  {
                         "Enabled":  true,
                         "ImapHost":  "imap.gmail.com",
                         "MaxRetries":  3,
                         "Username":  "",
                         "IntervalSeconds":  60,
                         "ReadTimeoutSeconds":  30,
                         "ConnectTimeoutSeconds":  10,
                         "BatchSize":  50,
                         "ImapPort":  993
                     },
    "ConnectionStrings":  {
                              "Default":  "Data Source=memolib.db"
                          },
    "UsePostgreSQL":  false,
    "JwtSettings":  {
                        "Audience":  "MemoLib.Client",
                        "SecretKey":  "CHANGE_ME_USE_USER_SECRETS_OR_KEYVAULT_MIN_32_CHARS",
                        "Issuer":  "MemoLib.Api",
                        "ExpirationMinutes":  1440
                    },
    "Cors":  {
                 "AllowedOrigins":  [
                                        "http://localhost:3000",
                                        "http://127.0.0.1:3000",
                                        "http://localhost:5078",
                                        "https://localhost:7009"
                                    ]
             },
    "Logging":  {
                    "LogLevel":  {
                                     "Microsoft.AspNetCore":  "Warning",
                                     "Default":  "Information"
                                 }
                },
    "DisableHttpsRedirection":  true
}
