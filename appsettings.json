{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=memolib.db"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_USE_KEYVAULT",
    "Issuer": "MemoLib.Api",
    "Audience": "MemoLib.Client",
    "ExpirationMinutes": 1440
  },
  "EmailMonitor": {
    "Enabled": false,
    "ImapHost": "imap.gmail.com",
    "ImapPort": 993,
    "Username": "",
    "IntervalSeconds": 60,
    "ConnectTimeoutSeconds": 10,
    "ReadTimeoutSeconds": 30,
    "MaxRetries": 3,
    "BatchSize": 50
  },
  "Vault": {
    "MasterKey": ""
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5078"
      },
      "Https": {
        "Url": "https://localhost:7009"
      }
    }
  }
}
